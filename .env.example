# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real tokens.

# Current Jenkins environment
JENKINS_CURRENT_URL=http://jenkins.example.com
JENKINS_CURRENT_USER=your_username
JENKINS_CURRENT_TOKEN=your_api_token

# Optional: add more environments following the pattern JENKINS_{ENV}_URL/USER/TOKEN
# JENKINS_LEGACY_URL=http://old-jenkins.example.com
# JENKINS_LEGACY_USER=your_username
# JENKINS_LEGACY_TOKEN=your_api_token
